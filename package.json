{
  "name": "carbuncle-plushy-qol",
  "version": "1.8.1",
  "private": true,
  "type": "module",
  "scripts": {
    "bench:e2e": "node scripts/benchmark-e2e.mjs",
    "build": "node scripts/build-userscript.mjs",
    "build:develop": "node scripts/build-userscript.mjs --channel=develop",
    "postbuild": "node scripts/sync-sonar-version.mjs",
    "sync:sonar": "node scripts/sync-sonar-version.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.include=src/** --coverage.exclude=ff14-carbuncle-plushy-qol.user.js",
    "test:watch": "vitest",
    "verify": "npm run test && npm run build"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.11",
    "playwright": "^1.58.2",
    "vitest": "^3.2.4"
  }
}
